#include<stdio.h>
#include<pthread.h>
#include<semaphore.h>
#include<unistd.h>

sem_t mutex, writeblock;
int data = 0, rcount = 0;

void *reader(void *arg){
    int f = *((int*)arg);

    sem_wait(&mutex);
    rcount++;
    if(rcount == 1)
        sem_wait(&writeblock);
    sem_post(&mutex);

    printf("Data read by the reader R[%d] is %d\n", f, data);
    sleep(1);

    sem_wait(&mutex);
    rcount--;
    if(rcount == 0)
        sem_post(&writeblock);
    sem_post(&mutex);

    return NULL;
}

void *writer(void *arg){
    int f = *((int*)arg);

    sem_wait(&writeblock);
    data++;
    printf("Data written by the writer W[%d] is %d\n", f, data);
    sleep(1);
    sem_post(&writeblock);

    return NULL;
}

int main(){
    int i;
    pthread_t rtid[10], wtid[10];
    int id[10];

    sem_init(&mutex, 0, 1);
    sem_init(&writeblock, 0, 1);

    for(i = 0; i <= 3; i++){
        id[i] = i;
        pthread_create(&wtid[i], NULL, writer, &id[i]);
        pthread_create(&rtid[i], NULL, reader, &id[i]);
    }

    for(i = 0; i <= 3; i++){
        pthread_join(wtid[i], NULL);
        pthread_join(rtid[i], NULL);
    }

    return 0;
}
