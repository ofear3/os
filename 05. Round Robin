#include <stdio.h>
int main() {
    int n, tq;
    printf("Enter number of processes: ");
    scanf("%d", &n);

    int pid[n], bt[n], rt[n], ct[n], tat[n], wt[n],i;

    printf("Enter burst times for all processes:");
    for (i = 0; i < n; i++) {
        pid[i] = i + 1;
        scanf("%d", &bt[i]);
        rt[i] = bt[i];
    }

    printf("Enter time quantum: ");
    scanf("%d", &tq);

    int time = 0, completed = 0;
    float totalwt = 0, totaltat = 0;

    while (completed < n) {
        for (int i = 0; i < n; i++) {
            if (rt[i] > 0) {
                if (rt[i] > tq) {
                    rt[i] -= tq;
                    time += tq;
                } 
                else {
                    time += rt[i];
                    rt[i] = 0;
                    ct[i] = time;
                    tat[i] = ct[i];
                    wt[i] = tat[i] - bt[i];
                    totalwt += wt[i];
                    totaltat += tat[i];
                    completed++;
                }
            }
        }
    }

    printf("\nPNo.\tAT\tBT\tCT\tTAT\tWT\n");
    for (int i = 0; i < n; i++) 
        printf("P%d\t\t%d\t%d\t%d\t%d\t%d\n",
               pid[i], bt[i], ct[i], tat[i], wt[i]);

    printf("\nAverage TAT = %.2f\n", totaltat/n);
    printf("Average WT = %.2f\n", totalwt/n);

    return 0;
}


